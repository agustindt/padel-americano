generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundKind {
  AMERICANO_RANDOM
  /// Sorteo de cruces 1v1 (dos jugadores por cancha).
  ONE_V_ONE_RANDOM
  MANUAL_SINGLE
  /// Un partido manual 1v1 (dos jugadores).
  MANUAL_ONE_V_ONE
}

enum MatchSource {
  AUTO
  MANUAL
}

enum RoundStatus {
  DRAFT
  CONFIRMED
  PLAYED
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users User[]
  rounds Round[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  groupId      String
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Restrict)

  matchesAsA1 Match[]       @relation("MatchPlayerA1")
  matchesAsA2 Match[]       @relation("MatchPlayerA2")
  matchesAsB1 Match[]       @relation("MatchPlayerB1")
  matchesAsB2 Match[]       @relation("MatchPlayerB2")
  sitOuts     RoundSitOut[]
}

model Round {
  id          String       @id @default(cuid())
  title       String?
  scheduledAt DateTime?
  venue       String?
  mapsUrl     String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  kind        RoundKind    @default(AMERICANO_RANDOM)
  status      RoundStatus  @default(CONFIRMED)
  groupId     String
  group       Group        @relation(fields: [groupId], references: [id], onDelete: Restrict)

  matches Match[]
  sitOuts RoundSitOut[]
}

model RoundSitOut {
  id      String @id @default(cuid())
  roundId String
  userId  String
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
}

model Match {
  id         String      @id @default(cuid())
  roundId    String
  courtLabel String?
  source     MatchSource @default(AUTO)

  playerA1Id String
  /// En partido 1v1 va en null (solo juegan A1 y B1).
  playerA2Id String?
  playerB1Id String
  playerB2Id String?

  /// [{ "a": 6, "b": 3 }, …] — al mejor de 3 sets (ej. 6–3 / 3–6 / 6–3).
  setScores Json?

  round    Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
  playerA1 User  @relation("MatchPlayerA1", fields: [playerA1Id], references: [id])
  playerA2 User? @relation("MatchPlayerA2", fields: [playerA2Id], references: [id])
  playerB1 User  @relation("MatchPlayerB1", fields: [playerB1Id], references: [id])
  playerB2 User? @relation("MatchPlayerB2", fields: [playerB2Id], references: [id])
}
