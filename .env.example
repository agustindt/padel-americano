# Copiá a .env y completá (no subir .env al repo).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Opcional en local: si no está, las migraciones usan DATABASE_URL. En Vercel + Neon (pooler), configurá DIRECT_URL
# con la URL "Direct" del dashboard (sin -pooler) para evitar P1002 en `prisma migrate deploy` del build.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"
AUTH_SECRET="generar_con_openssl_rand_base64_32"
AUTH_URL="https://tu-proyecto.vercel.app"
# Opcional: mínimo de partidos jugados para el bloque principal ordenado por % victorias en /posiciones (default 3).
# NEXT_PUBLIC_MIN_GAMES_FOR_RANKING="3"
